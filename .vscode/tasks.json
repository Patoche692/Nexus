{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "build engine",
            "command": "/usr/bin/g++",
            "args": [
                "-shared",
                "-fdiagnostics-color=always",
                "-o",
                "${workspaceFolder}/bin/nexus-engine.so",
                "-Wall",
                "-Wextra",
                "-fPIC",
                "${workspaceFolder}/nexus/src/nexus/*.cpp"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Task generated by Debugger."
        },
        {
            "type": "cppbuild",
            "label": "build nexus editor",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-o", "${workspaceFolder}/bin/nexus-editor",
                "-I",  "${workspaceFolder}/nexus/src",
                "-Wall",
                "-Wextra",
                "-g",
                "${workspaceFolder}/nexus-editor/src/**.cpp",
                "${workspaceFolder}/bin/nexus-engine.so"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger.",
            "dependsOn": ["build engine"]
        }
    ],
    "version": "2.0.0"
}